# ── LLM model selection ──
ENTSIM_LLM_ROUTINE_MODEL=anthropic/claude-haiku-4-5
ENTSIM_LLM_STANDARD_MODEL=anthropic/claude-sonnet-4-6
ENTSIM_LLM_COMPLEX_MODEL=anthropic/claude-opus-4-6

# ── LLM providers (required in prod; optional in dev — Ollama used instead) ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Qdrant ──
ENTSIM_QDRANT_URL=http://qdrant:6333
RAG_COLLECTION_NAME=enterprise_knowledge

# ── App settings ──
ENTSIM_LOG_LEVEL=INFO
